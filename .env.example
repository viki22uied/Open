MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
HF_TOKEN=hf_your_token_here
# OPENAI_API_KEY=sk-your-key-here  # Alternative to HF_TOKEN

# --- Environment Server ---
ENV_BASE_URL=http://localhost:7860

# --- Server Configuration ---
HOST=0.0.0.0
PORT=7860
